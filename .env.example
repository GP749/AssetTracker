# Path to the SQLite database file (relative to project root).
DATABASE_URL="file:./prisma/dev.db"

# Base URL baked into printed QR codes. Set to your laptop's LAN address
# (e.g. https://192.168.1.42:3000) before printing labels so phones can scan them.
APP_BASE_URL="http://localhost:3000"

# Optional. Get a free Access Key at https://unsplash.com/oauth/applications.
# Used by the seed script and the "Add tool" form to auto-fetch product photos.
UNSPLASH_ACCESS_KEY=""

# Checkouts older than this many days show an "overdue" warning.
OVERDUE_DAYS="14"

# 32+ random chars, used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""
